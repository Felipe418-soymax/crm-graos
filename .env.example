# ─────────────────────────────────────────────────────────────────────────────
# CRM Grãos — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores.
# ─────────────────────────────────────────────────────────────────────────────

# Ambiente: "development" ou "production"
NODE_ENV=production

# ── Banco de dados (SQLite via Prisma) ───────────────────────────────────────
# Local (desenvolvimento):
#   DATABASE_URL="file:./prisma/dev.db"
#
# Produção (VPS — caminho absoluto recomendado):
DATABASE_URL="file:/var/lib/crm-graos/prod.db"

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# OBRIGATÓRIO em produção. Gere uma chave segura:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# A chave deve ter 32+ caracteres. Em produção, NUNCA use o valor de exemplo.
JWT_SECRET=SUBSTITUA_POR_UMA_CHAVE_ALEATORIA_LONGA_SEGURA_32_CHARS_MINIMO

# ── URL pública do app (opcional, útil para links absolutos) ─────────────────
# NEXTAUTH_URL="https://crm.seudominio.com"
